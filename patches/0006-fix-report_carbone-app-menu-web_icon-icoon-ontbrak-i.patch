carbone_report_menu_root zette geen web_icon → "Document Generation" toonde een
blanco/niet-ladend icoon in het Odoo apps-menu. Wijst nu naar de meegeleverde
static/description/icon.png.

Co-Authored-By: Claude Opus 4.8 (1M context) <noreply@anthropic.com>
---
 report_carbone/views/carbone/report_carbone_menu.xml | 1 +
 1 file changed, 1 insertion(+)

diff --git a/report_carbone/views/carbone/report_carbone_menu.xml b/report_carbone/views/carbone/report_carbone_menu.xml
index 632774a..cf3984f 100644
--- a/report_carbone/views/carbone/report_carbone_menu.xml
+++ b/report_carbone/views/carbone/report_carbone_menu.xml
@@ -14,6 +14,7 @@
     <menuitem
         id="carbone_report_menu_root"
         name="Document Generation"
+        web_icon="report_carbone,static/description/icon.png"
         sequence="400"
         groups="report_carbone.group_report_carbone_viewer"
     />
