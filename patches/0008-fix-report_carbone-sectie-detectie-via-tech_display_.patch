From a89c113881e3fc84f8fa054b799aa79725f75288 Mon Sep 17 00:00:00 2001
From: Bram Buijs <b.buijs@bb-open.com>
Date: Fri, 12 Jun 2026 12:48:22 +0200
Subject: [PATCH 8/8] fix(report_carbone): sectie-detectie via
 tech_display_type (raw value)
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

export_json (JsonExportFormat) exporteert een selection als het LABEL
(display_type="Section") + een aparte tech_<field>-key met de raw waarde
("line_section"). De sectie-subtotaal-injectie checkte display_type=='line_section'
→ faalde. Nu robuust op tech_display_type én de label-varianten (single/multi-lang).
line_note telt niet mee in het subtotaal.

Co-Authored-By: Claude Opus 4.8 (1M context) <noreply@anthropic.com>
---
 .../models/base/ir_actions_report.py          | 22 +++++++++++++++----
 1 file changed, 18 insertions(+), 4 deletions(-)

diff --git a/report_carbone/models/base/ir_actions_report.py b/report_carbone/models/base/ir_actions_report.py
index e195602..14891f5 100644
--- a/report_carbone/models/base/ir_actions_report.py
+++ b/report_carbone/models/base/ir_actions_report.py
@@ -501,22 +501,36 @@ class IrActionsReportCarbone(models.Model):
         non-section-regels (tot de volgende section), zodat templates fase-totalen
         kunnen tonen. line_note-regels tellen niet mee.
         """
+        # export_json (JsonExportFormat) exporteert een selection als het LABEL
+        # (display_type="Section") + een aparte tech_<field>-key met de raw waarde
+        # ("line_section"). Check beide zodat het werkt ongeacht single/multi-lang.
+        def _is_section(x):
+            return isinstance(x, dict) and (
+                x.get("tech_display_type") == "line_section"
+                or x.get("display_type") in ("line_section", "Section")
+            )
+
+        def _is_note(x):
+            return isinstance(x, dict) and (
+                x.get("tech_display_type") == "line_note"
+                or x.get("display_type") in ("line_note", "Note")
+            )
+
         if isinstance(data, dict):
             for value in data.values():
                 self._carbone_fill_section_subtotals(value, sub_field)
         elif isinstance(data, list):
             for item in data:
                 self._carbone_fill_section_subtotals(item, sub_field)
-            if any(isinstance(x, dict) and x.get("display_type") == "line_section" for x in data):
+            if any(_is_section(x) for x in data):
                 current = None
                 for x in data:
                     if not isinstance(x, dict):
                         continue
-                    dt = x.get("display_type")
-                    if dt == "line_section":
+                    if _is_section(x):
                         x[sub_field] = 0.0
                         current = x
-                    elif not dt and current is not None and isinstance(x.get(sub_field), (int, float)):
+                    elif not _is_note(x) and current is not None and isinstance(x.get(sub_field), (int, float)):
                         current[sub_field] = (current.get(sub_field) or 0.0) + x[sub_field]
 
     def get_default_user_agent(self) -> str:
-- 
